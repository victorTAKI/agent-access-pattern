{
  "realm": "agents",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "accessTokenLifespan": 900,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,

  "roles": {
    "realm": [
      { "name": "user", "description": "Regular user" }
    ]
  },

  "users": [
    {
      "username": "demo",
      "enabled": true,
      "emailVerified": true,
      "email": "demo@example.com",
      "firstName": "Demo",
      "lastName": "User",
      "credentials": [
        { "type": "password", "value": "demo", "temporary": false }
      ],
      "realmRoles": ["user", "default-roles-agents"]
    }
  ],

  "clientScopes": [
    {
      "name": "mcp-gateway-audience",
      "description": "Adds mcp-gateway as audience of the access token",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "mcp-gateway-audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "mcp-gateway",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],

  "clients": [
    {
      "clientId": "ui-client",
      "name": "Streamlit UI",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:8501/*",
        "http://localhost:8501"
      ],
      "webOrigins": ["*"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "+"
      },
      "protocolMappers": [
        {
          "name": "agent-1-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "agent-1",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ],
      "defaultClientScopes": ["profile", "email", "roles"],
      "optionalClientScopes": ["offline_access"]
    },

    {
      "clientId": "agent-1",
      "name": "Agent 1 (Strands)",
      "enabled": true,
      "publicClient": false,
      "secret": "agent-1-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "authorizationServicesEnabled": false,
      "attributes": {
        "standard.token.exchange.enabled": "true",
        "token.exchange.grant.enabled": "true"
      },
      "defaultClientScopes": ["profile", "email", "roles", "mcp-gateway-audience"],
      "optionalClientScopes": []
    },

    {
      "clientId": "mcp-gateway",
      "name": "MCP Gateway (resource server)",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "secret": "mcp-gateway-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false
    }
  ],

  "smtpServer": {},
  "eventsEnabled": false,
  "adminEventsEnabled": false,
  "internationalizationEnabled": false,
  "browserSecurityHeaders": {
    "contentSecurityPolicy": "frame-src 'self' http://localhost:8501; frame-ancestors 'self' http://localhost:8501; object-src 'none';",
    "xFrameOptions": "ALLOWALL"
  }
}
