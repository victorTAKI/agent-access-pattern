# Copy this file to `.env` and adjust as needed.
# `docker compose` picks it up automatically.

# ---- Image registry ---------------------------------------------------------
# Where prebuilt images are pulled from. Set to your GHCR namespace.
IMAGE_REGISTRY=ghcr.io/victortaki/agent-access-pattern
IMAGE_TAG=latest

# ---- LLM provider (used by the Strands agent) -------------------------------
# `mock`     – no LLM, keyword-based routing. Works out of the box (default).
# `bedrock`  – AWS Bedrock. Requires AWS credentials in the container env.
# `openai`   – OpenAI or any OpenAI-compatible endpoint.
STRANDS_MODEL_PROVIDER=bedrock

# Bedrock
AWS_REGION=eu-west-3
BEDROCK_MODEL_ID=eu.anthropic.claude-sonnet-4-5-20250929-v1:0

# OpenAI / compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
